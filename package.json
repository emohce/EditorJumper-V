{
  "name": "EzVsEditorjumper",
  "displayName": "EzEditorJumper-V",
  "description": "A VS Code extension that allows you to seamlessly jump between JetBrains IDEs and other popular code editors (such as VS Code, Cursor, Trae, and Windsurf). It maintains your cursor position and editing context, greatly improving development efficiency in multi-editor environments.",
  "version": "2.0.5",
  "publisher": "emohce",
  "repository": {
    "type": "git",
    "url": "https://github.com/emohce/EditorJumper-V.git"
  },
  "engines": {
    "vscode": "^1.81.0"
  },
  "icon": "image/pluginIcon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "intellij",
    "idea",
    "jetbrains",
    "jump",
    "open",
    "editor",
    "cursor",
    "trae",
    "windsurf"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "editorjumper.openInJetBrains",
        "title": "Open in JetBrains IDE"
      },
      {
        "command": "editorjumper.openInJetBrainsFast",
        "title": "Open in JetBrains IDE (Fast Mode)"
      },
      {
        "command": "editorjumper.selectJetBrainsIDE",
        "title": "Select JetBrains IDE"
      },
      {
        "command": "editorjumper.configureIDE",
        "title": "Configure Ez-EditorJumper-V"
      },
      {
        "command": "editorjumper.openSlot1",
        "title": "Ez-EditorJumper-V: Open in Slot 1 Editor"
      },
      {
        "command": "editorjumper.openSlot1Fast",
        "title": "Ez-EditorJumper-V: Open in Slot 1 Editor (Fast Mode)"
      },
      {
        "command": "editorjumper.openSlot2",
        "title": "Ez-EditorJumper-V: Open in Slot 2 Editor"
      },
      {
        "command": "editorjumper.openSlot3",
        "title": "Ez-EditorJumper-V: Open in Slot 3 Editor"
      },
      {
        "command": "editorjumper.openSlot2Cursor",
        "title": "Ez-EditorJumper-V: Open in Cursor"
      },
      {
        "command": "editorjumper.openSlot2Windsurf",
        "title": "Ez-EditorJumper-V: Open in Windsurf"
      },
      {
        "command": "editorjumper.openSlot2VSCode",
        "title": "Ez-EditorJumper-V: Open in Visual Studio Code"
      },
      {
        "command": "editorjumper.openSlot3Cursor",
        "title": "Ez-EditorJumper-V: Open in Cursor"
      },
      {
        "command": "editorjumper.openSlot3Windsurf",
        "title": "Ez-EditorJumper-V: Open in Windsurf"
      },
      {
        "command": "editorjumper.openSlot3VSCode",
        "title": "Ez-EditorJumper-V: Open in Visual Studio Code"
      },
      {
        "command": "editorjumper.openInEditor",
        "title": "Ez-EditorJumper-V: Open in Editor..."
      },
      {
        "command": "editorjumper.configureSlot",
        "title": "Ez-EditorJumper-V: Configure Slot Target"
      },
      {
        "command": "editorjumper.jumpBack",
        "title": "Ez-EditorJumper-V: Jump Back to Source Editor"
      },
      {
        "command": "editorjumper.openInPeerVscodeApp",
        "title": "Ez-EditorJumper-V: Open in Peer VSCode App"
      },
      {
        "command": "editorjumper.pickSlotToJump",
        "title": "Ez-EditorJumper-V: Pick Slot to Jump"
      }
    ],
    "keybindings": [
      {
        "command": "editorjumper.openSlot1",
        "key": "shift+alt+o"
      },
      {
        "command": "editorjumper.openSlot1Fast",
        "key": "shift+alt+p"
      },
      {
        "command": "editorjumper.openSlot2",
        "key": "shift+alt+i",
        "when": "editorjumper.slot2MenuTarget == 'generic'"
      },
      {
        "command": "editorjumper.openSlot3",
        "key": "shift+alt+u",
        "when": "editorjumper.slot3MenuTarget == 'generic'"
      },
      {
        "command": "editorjumper.openSlot2Cursor",
        "key": "shift+alt+i",
        "when": "editorjumper.slot2MenuTarget == 'cursor'"
      },
      {
        "command": "editorjumper.openSlot2Windsurf",
        "key": "shift+alt+i",
        "when": "editorjumper.slot2MenuTarget == 'windsurf'"
      },
      {
        "command": "editorjumper.openSlot2VSCode",
        "key": "shift+alt+i",
        "when": "editorjumper.slot2MenuTarget == 'vscode'"
      },
      {
        "command": "editorjumper.openSlot3Cursor",
        "key": "shift+alt+u",
        "when": "editorjumper.slot3MenuTarget == 'cursor'"
      },
      {
        "command": "editorjumper.openSlot3Windsurf",
        "key": "shift+alt+u",
        "when": "editorjumper.slot3MenuTarget == 'windsurf'"
      },
      {
        "command": "editorjumper.openSlot3VSCode",
        "key": "shift+alt+u",
        "when": "editorjumper.slot3MenuTarget == 'vscode'"
      },
      {
        "command": "editorjumper.jumpBack",
        "key": "shift+alt+b"
      },
      {
        "command": "editorjumper.openInPeerVscodeApp",
        "key": "shift+alt+v"
      },
      {
        "command": "editorjumper.configureIDE",
        "key": "ctrl+shift+alt+v",
        "mac": "cmd+shift+alt+v"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "editorjumper.openInJetBrains",
          "group": "navigation",
          "when": "editorTextFocus"
        },
        {
          "command": "editorjumper.openSlot2Cursor",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot2MenuTarget == 'cursor'"
        },
        {
          "command": "editorjumper.openSlot2Windsurf",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot2MenuTarget == 'windsurf'"
        },
        {
          "command": "editorjumper.openSlot2VSCode",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot2MenuTarget == 'vscode'"
        },
        {
          "command": "editorjumper.openSlot2",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot2MenuTarget == 'generic'"
        },
        {
          "command": "editorjumper.openSlot3Cursor",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot3MenuTarget == 'cursor'"
        },
        {
          "command": "editorjumper.openSlot3Windsurf",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot3MenuTarget == 'windsurf'"
        },
        {
          "command": "editorjumper.openSlot3VSCode",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot3MenuTarget == 'vscode'"
        },
        {
          "command": "editorjumper.openSlot3",
          "group": "navigation",
          "when": "editorTextFocus && editorjumper.slot3MenuTarget == 'generic'"
        },
        {
          "command": "editorjumper.openInPeerVscodeApp",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "editorjumper.openInJetBrains",
          "group": "navigation"
        },
        {
          "command": "editorjumper.openSlot2Cursor",
          "group": "navigation",
          "when": "editorjumper.slot2MenuTarget == 'cursor'"
        },
        {
          "command": "editorjumper.openSlot2Windsurf",
          "group": "navigation",
          "when": "editorjumper.slot2MenuTarget == 'windsurf'"
        },
        {
          "command": "editorjumper.openSlot2VSCode",
          "group": "navigation",
          "when": "editorjumper.slot2MenuTarget == 'vscode'"
        },
        {
          "command": "editorjumper.openSlot2",
          "group": "navigation",
          "when": "editorjumper.slot2MenuTarget == 'generic'"
        },
        {
          "command": "editorjumper.openSlot3Cursor",
          "group": "navigation",
          "when": "editorjumper.slot3MenuTarget == 'cursor'"
        },
        {
          "command": "editorjumper.openSlot3Windsurf",
          "group": "navigation",
          "when": "editorjumper.slot3MenuTarget == 'windsurf'"
        },
        {
          "command": "editorjumper.openSlot3VSCode",
          "group": "navigation",
          "when": "editorjumper.slot3MenuTarget == 'vscode'"
        },
        {
          "command": "editorjumper.openSlot3",
          "group": "navigation",
          "when": "editorjumper.slot3MenuTarget == 'generic'"
        },
        {
          "command": "editorjumper.openInPeerVscodeApp",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Ez-EditorJumper-V",
      "properties": {
        "editorjumper.collapsedSections": {
          "type": "object",
          "default": {
            "jetbrains-section": true,
            "vscode-section": true
          },
          "description": "Collapse state of configuration sections. Stored across VSCode-based editors."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "editorjumperPanel",
          "title": "EzEditorJumper-V",
          "icon": "$(link-external)"
        }
      ]
    },
    "views": {
      "editorjumperPanel": [
        {
          "type": "webview",
          "id": "editorjumper.slotPicker",
          "name": "Jump Slots"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "pnpm run lint",
    "test": "vscode-test",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~20.17.24",
    "@types/vscode": "^1.81.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.3.0",
    "eslint": "^9.22.0"
  }
}
