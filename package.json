{
  "name": "editorjumper",
  "displayName": "EditorJumper",
  "description": "A VS Code extension that allows you to seamlessly jump between JetBrains IDEs and other popular code editors (such as VS Code, Cursor, Trae, and Windsurf). It maintains your cursor position and editing context, greatly improving development efficiency in multi-editor environments.",
  "version": "1.2.0",
  "publisher": "wanniwa",
  "repository": {
    "type": "git",
    "url": "https://github.com/wanniwa/EditorJumper-V"
  },
  "bugs": {
    "url": "https://github.com/wanniwa/EditorJumper-V/issues"
  },
  "homepage": "https://github.com/wanniwa/EditorJumper-V#readme",
  "engines": {
    "vscode": "^1.81.0"
  },
  "icon": "image/pluginIcon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "intellij",
    "idea",
    "jetbrains",
    "jump",
    "open",
    "editor",
    "cursor",
    "trae",
    "windsurf"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "editorjumper.openInJetBrains",
        "title": "Open in JetBrains IDE"
      },
      {
        "command": "editorjumper.openInJetBrainsFast",
        "title": "Open in JetBrains IDE (Fast Mode)"
      },
      {
        "command": "editorjumper.selectJetBrainsIDE",
        "title": "Select JetBrains IDE"
      },
      {
        "command": "editorjumper.configureIDE",
        "title": "Configure EditorJumper"
      },
      {
        "command": "editorjumper.openSlot1",
        "title": "EditorJumper: Open in Slot 1 Editor"
      },
      {
        "command": "editorjumper.openSlot2",
        "title": "EditorJumper: Open in Slot 2 Editor"
      },
      {
        "command": "editorjumper.openSlot3",
        "title": "EditorJumper: Open in Slot 3 Editor"
      },
      {
        "command": "editorjumper.openInEditor",
        "title": "EditorJumper: Open in Editor..."
      },
      {
        "command": "editorjumper.configureSlot",
        "title": "EditorJumper: Configure Slot Target"
      },
      {
        "command": "editorjumper.jumpBack",
        "title": "EditorJumper: Jump Back to Source Editor"
      }
    ],
    "keybindings": [
      {
        "command": "editorjumper.openInJetBrains",
        "key": "shift+alt+o"
      },
      {
        "command": "editorjumper.openInJetBrainsFast",
        "key": "shift+alt+p"
      },
      {
        "command": "editorjumper.openSlot2",
        "key": "shift+alt+i"
      },
      {
        "command": "editorjumper.openSlot3",
        "key": "shift+alt+u"
      },
      {
        "command": "editorjumper.jumpBack",
        "key": "shift+alt+b"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "editorjumper.openInJetBrains",
          "group": "navigation",
          "when": "editorTextFocus"
        },
        {
          "command": "editorjumper.openSlot2",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "editorjumper.openInJetBrains",
          "group": "navigation"
        },
        {
          "command": "editorjumper.openSlot2",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "EditorJumper",
      "properties": {
        "editorjumper.selectedIDE": {
          "type": "string",
          "default": "IDEA",
          "description": "Currently selected JetBrains IDE"
        },
        "editorjumper.ideConfigurations": {
          "type": "array",
          "default": [
            {
              "name": "IDEA",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "WebStorm",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "PyCharm",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "GoLand",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "CLion",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "PhpStorm",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "RubyMine",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "Rider",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            },
            {
              "name": "Android Studio",
              "isCustom": false,
              "hidden": false,
              "commandPath": null
            }
          ],
          "description": "Configured JetBrains IDEs",
          "items": {
            "type": "object",
            "required": [
              "name",
              "isCustom",
              "hidden"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the IDE"
              },
              "isCustom": {
                "type": "boolean",
                "description": "Whether this is a custom IDE",
                "default": false
              },
              "hidden": {
                "type": "boolean",
                "description": "Whether to hide this IDE in the selection menu",
                "default": false
              },
              "commandPath": {
                "type": ["string", "null"],
                "description": "Command or path to open the IDE"
              }
            }
          }
        },
        "editorjumper.jetBrainsRootProjectPath": {
          "type": "string",
          "default": "",
          "description": "Optional JetBrains root project path (directory containing .idea). Used for multi-module or multi-root workspaces; when set, jump opens this project. Leave empty to use workspace folder as project path."
        },
        "editorjumper.slotTargets": {
          "type": "array",
          "default": [
            { "slot": 1, "type": "jetbrains", "target": "" },
            { "slot": 2, "type": "vscode-app", "target": "" },
            { "slot": 3, "type": "vscode-app", "target": "" }
          ],
          "description": "Shortcut slot targets. Each slot has a type (jetbrains or vscode-app) and a target editor name. Slot 1 defaults to selected JetBrains IDE, Slot 2 auto-detects peer editor.",
          "items": {
            "type": "object",
            "required": ["slot", "type", "target"],
            "properties": {
              "slot": {
                "type": "integer",
                "description": "Slot number (1, 2, or 3)"
              },
              "type": {
                "type": "string",
                "enum": ["jetbrains", "vscode-app"],
                "description": "Editor type: jetbrains or vscode-app"
              },
              "target": {
                "type": "string",
                "description": "Target editor name (e.g. IDEA, Cursor, Windsurf)"
              }
            }
          }
        },
        "editorjumper.vscodeAppConfigurations": {
          "type": "array",
          "default": [
            { "name": "Visual Studio Code", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "Cursor", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "Windsurf", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "Trae", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "Void", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "Kiro", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "Qoder", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "CatPawAI", "commandPath": null, "isCustom": false, "hidden": false },
            { "name": "Antigravity", "commandPath": null, "isCustom": false, "hidden": false }
          ],
          "description": "Configured VSCode-rooted editors",
          "items": {
            "type": "object",
            "required": ["name", "isCustom", "hidden"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the editor"
              },
              "isCustom": {
                "type": "boolean",
                "description": "Whether this is a custom editor",
                "default": false
              },
              "hidden": {
                "type": "boolean",
                "description": "Whether to hide this editor in the selection menu",
                "default": false
              },
              "commandPath": {
                "type": ["string", "null"],
                "description": "Command or path to open the editor"
              }
            }
          }
        },
        "editorjumper.jumpBackSource": {
          "type": "string",
          "default": "",
          "description": "Internal: source editor name for jump-back. Automatically set when jumping to another editor."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "pnpm run lint",
    "test": "vscode-test",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~20.17.24",
    "@types/vscode": "^1.81.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.3.0",
    "eslint": "^9.22.0"
  }
}
